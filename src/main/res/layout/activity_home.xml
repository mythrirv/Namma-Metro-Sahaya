<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_color">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="100dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- HERO HEADER -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#1a237e"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="40dp"
                android:paddingBottom="20dp">

                <ImageButton
                    android:id="@+id/btnHamburger"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_alignParentEnd="true"
                    android:layout_alignParentTop="true"
                    android:src="@android:drawable/ic_menu_sort_by_size"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:tint="#ffffff"
                    android:contentDescription="Menu"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_toStartOf="@id/btnHamburger">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🚇 Namma Metro Sahaya"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#ffffff"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ನಮ್ಮ ಮೆಟ್ರೋ ಸಹಾಯ"
                        android:textSize="15sp"
                        android:textColor="#90caf9"
                        android:layout_marginTop="2dp"/>

                    <View
                        android:layout_width="40dp"
                        android:layout_height="2dp"
                        android:background="#90caf9"
                        android:layout_marginTop="10dp"
                        android:layout_marginBottom="10dp"/>

                    <TextView
                        android:id="@+id/tvWelcome"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Welcome, User"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#ffffff"/>

                    <TextView
                        android:id="@+id/tvEmail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="user@email.com"
                        android:textSize="13sp"
                        android:textColor="#90caf9"
                        android:layout_marginTop="2dp"/>

                </LinearLayout>

            </RelativeLayout>

            <!-- GLOBAL SEARCH BAR -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#1a237e"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingBottom="16dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="28dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="@color/card_background">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🔍"
                            android:textSize="18sp"/>

                        <EditText
                            android:id="@+id/etGlobalSearch"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:hint="Search stations, routes, exits..."
                            android:textSize="14sp"
                            android:background="@null"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_secondary"
                            android:imeOptions="actionSearch"
                            android:inputType="text"
                            android:maxLines="1"/>

                        <TextView
                            android:id="@+id/btnClearSearch"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="✕"
                            android:textSize="16sp"
                            android:textColor="@color/text_secondary"
                            android:padding="8dp"
                            android:visibility="gone"/>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- SEARCH RESULTS -->
            <LinearLayout
                android:id="@+id/layoutSearchResults"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="8dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Search Results"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="8dp"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvSearchResults"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"/>

            </LinearLayout>

            <!-- CARDS SECTION -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Route Finder — Blue -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardRouteFinder"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="@color/card_background"
                    app:strokeColor="#3949AB"
                    app:strokeWidth="2dp"
                    android:layout_marginBottom="12dp"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="20dp"
                        android:gravity="center_vertical"
                        android:background="?attr/selectableItemBackground">

                        <TextView
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:text="🗺️"
                            android:textSize="36sp"
                            android:gravity="center"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Route Finder"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_primary"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Find the best metro route"
                                android:textSize="13sp"
                                android:textColor="@color/text_secondary"/>

                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textSize="28sp"
                            android:textColor="#3949AB"/>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Visual Guide — Purple -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardVisualGuide"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="@color/card_background"
                    app:strokeColor="#7B1FA2"
                    app:strokeWidth="2dp"
                    android:layout_marginBottom="12dp"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="20dp"
                        android:gravity="center_vertical"
                        android:background="?attr/selectableItemBackground">

                        <TextView
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:text="👁️"
                            android:textSize="36sp"
                            android:gravity="center"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Visual Guide"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_primary"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Step-by-step metro instructions"
                                android:textSize="13sp"
                                android:textColor="@color/text_secondary"/>

                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textSize="28sp"
                            android:textColor="#7B1FA2"/>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Exit Finder — Green -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardExitFinder"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="@color/card_background"
                    app:strokeColor="#00897B"
                    app:strokeWidth="2dp"
                    android:layout_marginBottom="12dp"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="20dp"
                        android:gravity="center_vertical"
                        android:background="?attr/selectableItemBackground">

                        <TextView
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:text="🚪"
                            android:textSize="36sp"
                            android:gravity="center"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Exit Finder"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_primary"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Which gate leads where?"
                                android:textSize="13sp"
                                android:textColor="@color/text_secondary"/>

                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textSize="28sp"
                            android:textColor="#00897B"/>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Fare & Time — Orange -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardFare"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="@color/card_background"
                    app:strokeColor="#F57C00"
                    app:strokeWidth="2dp"
                    android:layout_marginBottom="12dp"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="20dp"
                        android:gravity="center_vertical"
                        android:background="?attr/selectableItemBackground">

                        <TextView
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:text="💰"
                            android:textSize="36sp"
                            android:gravity="center"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Fare &amp; Time"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_primary"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Check ticket price and travel time"
                                android:textSize="13sp"
                                android:textColor="@color/text_secondary"/>

                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textSize="28sp"
                            android:textColor="#F57C00"/>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- AI Assistant Circle FAB -->
    <LinearLayout
        android:id="@+id/fabAiContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_margin="20dp">

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/cardAiAssistant"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:src="@android:drawable/ic_dialog_info"
            app:backgroundTint="#00ACC1"
            app:tint="#ffffff"
            app:fabSize="normal"
            android:contentDescription="AI Assistant"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AI Assistant"
            android:textSize="11sp"
            android:textColor="#00ACC1"
            android:textStyle="bold"
            android:layout_marginTop="4dp"
            android:layout_gravity="center"/>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>