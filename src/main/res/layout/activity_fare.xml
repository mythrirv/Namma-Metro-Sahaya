<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_color">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:background="#1a237e">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💰 Fare &amp; Time"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#ffffff"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Calculate ticket price and travel time"
                    android:textSize="13sp"
                    android:textColor="#90caf9"
                    android:layout_marginTop="4dp"/>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Input Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- From Station - centered text, underline style -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="From Station"
                    style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox">

                    <AutoCompleteTextView
                        android:id="@+id/etFrom"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:completionThreshold="1"
                        android:maxLines="1"
                        android:gravity="center"
                        android:textAlignment="center"
                        android:textSize="16sp"/>

                </com.google.android.material.textfield.TextInputLayout>

                <!-- To Station - centered text, underline style -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="To Station"
                    android:layout_marginTop="16dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox">

                    <AutoCompleteTextView
                        android:id="@+id/etTo"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:completionThreshold="1"
                        android:maxLines="1"
                        android:gravity="center"
                        android:textAlignment="center"
                        android:textSize="16sp"/>

                </com.google.android.material.textfield.TextInputLayout>

                <!-- Calculate button only — back button removed, use top-left arrow -->
                <Button
                    android:id="@+id/btnCalculate"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="CALCULATE"
                    android:textSize="16sp"
                    android:layout_marginTop="20dp"
                    android:backgroundTint="#1a237e"/>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Results Card — hidden until calculation is done -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardResults"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="16dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Results"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#00E5FF"
                    android:layout_marginBottom="16dp"/>

                <!-- Fare Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🎫 Ticket Fare"
                        android:textSize="15sp"
                        android:textColor="@color/text_primary"/>

                    <TextView
                        android:id="@+id/tvFareResult"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₹--"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#4CAF50"/>

                </LinearLayout>

                <!-- Time Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="⏱️ Travel Time"
                        android:textSize="15sp"
                        android:textColor="@color/text_primary"/>

                    <TextView
                        android:id="@+id/tvTimeResult"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-- mins"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#FFB74D"/>

                </LinearLayout>

                <!-- Distance Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="📍 Distance"
                        android:textSize="15sp"
                        android:textColor="@color/text_primary"/>

                    <TextView
                        android:id="@+id/tvDistanceResult"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-- km"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#64B5F6"/>

                </LinearLayout>

                <!-- Stations Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🚉 Stations"
                        android:textSize="15sp"
                        android:textColor="@color/text_primary"/>

                    <TextView
                        android:id="@+id/tvStationsResult"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#CE93D8"/>

                </LinearLayout>

                <!-- Interchange Note -->
                <TextView
                    android:id="@+id/tvInterchangeNote"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="13sp"
                    android:textColor="#e65100"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp"/>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</ScrollView>